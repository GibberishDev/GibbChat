{
  "name": "gibbchat",
  "desktopName": "com.gibbdev.gibbchat.desktop",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/GibberishDev/GibbChat#readme",
  "bugs": {
    "url": "https://github.com/GibberishDev/GibbChat/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GibberishDev/GibbChat.git"
  },
  "license": "LGPL-3.0-or-later",
  "author": "GibbDev",
  "type": "commonjs",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "app:dir": "electron-builder --dir",
    "app:dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "tmi.js": "^1.8.5",
    "youtube-chat": "^2.2.0"
  },
  "build": {
    "appId": "gibbdev.gibbchat",
