        "AppImage"
      ],
      "category": "AudioVideo",
      "synopsis": "Streaming utility",
      "vendor": "GibberishDev",
      "maintainer": "GibbDev GibberishDevelopment@gmail.com",
      "syncDesktopName": true,
      "desktop": {
        "entry": {
          "Name": "GibbChat",
          "Comment": "Streaming utility",
          "Categories": "AudioVideo",
          "Type": "Application",
          "StartupWMClass": "gibbchat"
        }
      }
    }
  }
